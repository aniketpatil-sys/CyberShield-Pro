# ═══════════════════════════════════════════════════════
#  CyberShield Pro — Environment Configuration
#  Copy to .env and populate. NEVER commit .env to git.
# ═══════════════════════════════════════════════════════

# ── VirusTotal (required for live cross-checks) ────────
# Get your key: https://www.virustotal.com/gui/my-apikey
VT_API_KEY= your virustotal api key

# ── Admin credentials ──────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS= your admin password

# ── Flask ──────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
FLASK_DEBUG=true
PORT=5000
